# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

# The following `prisma+postgres` URL is similar to the URL produced by running a local Prisma Postgres 
# server with the `prisma dev` CLI command, when not choosing any non-default ports or settings. The API key, unlike the 
# one found in a remote Prisma Postgres URL, does not contain any sensitive information.

# Connect to Supabase via connection pooling
DATABASE_URL="YOUR_SUPABASE_CONNECTION_STRING"
# OpenRouter API Key
OPEN_ROUTER_API ="YOUR_OPEN_ROUTER_API"

# Gemini API Key
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Groq API Key
GROQ_API_KEY="YOUR_GROQ_API_KEY"

# Google Client ID
GOOGLE_CLIENT_ID=CLIENT_ID
# Google Client Secret
GOOGLE_CLIENT_SECRET=CLIENT_SECRET

# NextAuth.js Secret
NEXTAUTH_SECRET=some-secret-value
NEXTAUTH_URL=your-url-domain

# CloudFlared
CLOUDFLARE_TUNNEL_TOKEN="your token"
# Web Push (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your public key"
VAPID_PRIVATE_KEY="your private key"
VAPID_EMAIL="mailto:yourmail@gmail.com"

# Email (Resend) - daftar di resend.com untuk mendapatkan API key
RESEND_API_KEY="your resend api key"
EMAIL_FROM="Your name <onboarding@resend.dev>"

# Cron Secret - isi dengan random string panjang
CRON_SECRET="your cron secret here"
